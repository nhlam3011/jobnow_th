// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
  output          = "../jobnow/generated/prisma"
}

datasource db {
  provider   = "postgresql"
  extensions = [pgvector(map: "vector")]
}

// ============================================================
// ENUMS
// ============================================================

enum UserRole {
  CANDIDATE
  EMPLOYER
  ADMIN
}

enum JobType {
  FULL_TIME
  PART_TIME
  REMOTE
  INTERNSHIP
  CONTRACT
}

enum JobStatus {
  PENDING
  ACTIVE
  CLOSED
  REJECTED
}

enum ApplicationStatus {
  PENDING
  REVIEWING
  INTERVIEW
  ACCEPTED
  REJECTED
}

// ============================================================
// MODELS
// ============================================================

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  password      String?
  name          String?
  image         String?
  role          UserRole  @default(CANDIDATE)
  emailVerified DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  candidateProfile CandidateProfile?
  employerProfile  EmployerProfile?
  applications     Application[]
  resumes          Resume[]
  notifications    Notification[]

  @@index([email])
}

model CandidateProfile {
  id             String   @id @default(cuid())
  userId         String   @unique
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  phone          String?
  location       String?
  bio            String?
  yearsExp       Int      @default(0)
  desiredSalary  Int?
  desiredJobType String?
  skills         String[]
  education      Json? // [{ school, degree, field, startYear, endYear }]
  experience     Json? // [{ company, position, startDate, endDate, description }]
  resumeUrl      String?
  // embedding stored via raw SQL: ALTER TABLE "CandidateProfile" ADD COLUMN embedding vector(1536);
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Company {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  logo        String?
  coverImage  String?
  website     String?
  description String?
  industry    String?
  size        String? // "1-10", "11-50", "51-200", "201-500", "500+"
  location    String?
  verified    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  employers EmployerProfile[]
  jobs      Job[]

  @@index([slug])
  @@index([industry])
}

model EmployerProfile {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  companyId String?
  company   Company? @relation(fields: [companyId], references: [id])
  position  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Job {
  id           String    @id @default(cuid())
  companyId    String
  company      Company   @relation(fields: [companyId], references: [id])
  postedById   String?
  title        String
  slug         String    @unique
  description  String
  requirements String?
  benefits     String?
  salaryMin    Int?
  salaryMax    Int?
  location     String
  jobType      JobType   @default(FULL_TIME)
  status       JobStatus @default(PENDING)
  skills       String[]
  // embedding stored via raw SQL
  viewCount    Int       @default(0)
  expiresAt    DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  applications Application[]

  @@index([status])
  @@index([location])
  @@index([jobType])
  @@index([companyId])
  @@index([slug])
}

model Application {
  id          String            @id @default(cuid())
  jobId       String
  job         Job               @relation(fields: [jobId], references: [id])
  candidateId String
  candidate   User              @relation(fields: [candidateId], references: [id])
  status      ApplicationStatus @default(PENDING)
  coverLetter String?
  matchScore  Float?
  notes       String? // Employer's internal notes
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@unique([jobId, candidateId])
  @@index([candidateId])
  @@index([jobId])
}

model Resume {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  fileName   String
  fileUrl    String
  parsedText String?
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())

  @@index([userId])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String // APPLICATION_STATUS, NEW_JOB_MATCH, JOB_APPROVED, etc.
  title     String
  message   String
  isRead    Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())

  @@index([userId, isRead])
}

model Skill {
  id       String @id @default(cuid())
  name     String @unique
  category String // Frontend, Backend, AI/ML, Design, DevOps, etc.
}

model Industry {
  id   String @id @default(cuid())
  name String @unique
  slug String @unique
}
