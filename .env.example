# ============================================================
# DATABASE 
# ============================================================
# Replace with your PostgreSQL connection database string
DATABASE_URL="postgresql://user:password@host:port/database"
DIRECT_URL="postgresql://user:password@host:port/database"

# ============================================================
# AUTHENTICATION (NextAuth v5)
# ============================================================
# A random secret used to hash tokens, sign/encrypt cookies and generate cryptographic keys
# Generate a new one in terminal with: npx auth secret
AUTH_SECRET="replace_with_a_secure_random_string_in_production"

# Replace with your app's canonical URL in production
AUTH_URL="http://localhost:3000"

# Google OAuth (Planned integration)
# AUTH_GOOGLE_ID=""
# AUTH_GOOGLE_SECRET=""

# ============================================================
# AI & SEARCH (Postgres pgvector + Gemini)
# ============================================================
GEMINI_API_KEY="AIzaSyA0nWcrF6VsHI5GJFqs5U1n80rY4TnZX8g"

# Chat Model (default: gemini-2.0-flash)
# Options: gemini-2.0-flash, gemini-2.0-flash-lite, gemini-1.5-pro, gemini-1.5-flash, gemini-1.5-flash-8b
GEMINI_CHAT_MODEL="gemini-2.0-flash"

# Embedding Model (default: text-embedding-004)
# Options: text-embedding-004, gemini-embedding-001
GEMINI_EMBEDDING_MODEL="text-embedding-004"

